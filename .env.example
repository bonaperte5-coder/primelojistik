# Prime Express Lojistik — Environment Variables
# Bu dosyayı kopyalayarak .env oluşturun:
#   cp .env.example .env
# .env dosyasını asla git'e commit ETMEYİN.

# Sunucu portu (varsayılan: 3000)
PORT=3000

# ─── SMTP (e-posta gönderimi için zorunlu) ───────────────────────────────────
# Gmail örneği:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=info@primeexpresslojistik.com
#   SMTP_PASS=uygulama-sifresi-buraya   (App Password, 2FA aktif olmalı)
#
# Yandex örneği:
#   SMTP_HOST=smtp.yandex.com
#   SMTP_PORT=465
#   SMTP_SECURE=true
#
# Gerekli olmayan durumlarda (Formspree kullanıyorsanız) bu satırları boş bırakın.

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=

# Form gönderimlerinin iletileceği e-posta (boş bırakılırsa SMTP_USER kullanılır)
MAIL_TO=info@primeexpresslojistik.com
