{
  "version": 2,
  "builds": [
    { "src": "api/contact.js", "use": "@vercel/node" },
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/contact", "dest": "/api/contact.js" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/robots\\.txt", "dest": "/robots.txt" },
    { "src": "/sitemap\\.xml", "dest": "/sitemap.xml" },
    { "src": "/", "dest": "/index.html" }
  ]
}
