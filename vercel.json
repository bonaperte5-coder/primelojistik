{
  "version": 2,
  "builds": [
    { "src": "api/contact.js", "use": "@vercel/node" },
    { "src": "**/*", "use": "@vercel/static" }
  ],
  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "www.primeexpresslojistik.com" }],
      "destination": "https://primeexpresslojistik.com/:path*",
      "permanent": true
    }
  ],
  "routes": [
    { "src": "/api/contact", "dest": "/api/contact.js" },
    { "src": "/sitemap\\.xml", "dest": "/sitemap.xml" },
    { "src": "/robots\\.txt", "dest": "/robots.txt" },
    { "src": "/googlee6837f5456e4e913\\.html", "dest": "/googlee6837f5456e4e913.html" },
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/hizmetler/(.*\\.html)", "dest": "/hizmetler/$1" },
    { "src": "/(.*\\.html)", "dest": "/$1" },
    { "src": "/", "dest": "/index.html" }
  ]
}
